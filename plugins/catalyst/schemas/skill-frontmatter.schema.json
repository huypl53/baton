{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-frontmatter.schema.json",
  "title": "SKILL.md Frontmatter",
  "description": "Schema for SKILL.md YAML frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Skill name (lowercase, alphanumeric with hyphens)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Skill description for discovery"
    },
    "argument-hint": {
      "type": "string",
      "maxLength": 100,
      "description": "Usage hint for arguments"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
