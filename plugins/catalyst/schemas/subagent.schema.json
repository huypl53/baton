{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subagent.schema.json",
  "title": "Subagent Definition",
  "description": "Schema for agents/*.md frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Subagent name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "What this subagent does"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tools this subagent uses"
    }
  },
  "additionalProperties": false
}
